# Copy this file to .env and replace local paths before running the real API.

# JSON dataset. Use examples/dataset.sample.json for a smoke test, or point to your real dataset.
DATASET_PATH=examples/dataset.sample.json

# SentenceTransformer model name or local model directory.
# If this value is a Hugging Face model name, the first run may need internet access.
DENSE_ENCODER_PATH=sentence-transformers/all-MiniLM-L6-v2

# Local GGUF model path for llama-cpp-python. Do not commit model files.
MODEL_PATH=app/Models/model.gguf

# Elasticsearch and Redis.
ES_HOST=http://localhost:9200
ES_INDEX=answerai-docs
REDIS_HOST=localhost
REDIS_PORT=6379

# API host and port.
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000
